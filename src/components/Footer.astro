---
<footer id="kontak" class="footer">
  <!-- CTA Section -->
  <div class="footer-cta">
    <div class="container cta-inner">
      <div class="cta-content reveal">
        <div class="section-tag" style="color: rgba(255,255,255,0.5)">
          <span style="background:rgba(255,255,255,0.3);display:block;width:20px;height:1.5px;"></span>
          Mulai Sekarang
        </div>
        <h2 class="cta-title">
          Siap Memulai<br />
          <em>Proyek Bersama?</em>
        </h2>
        <p class="cta-desc">
          Konsultasi pertama gratis, tanpa komitmen. Tim kami siap mendengar kebutuhan bisnis Anda.
        </p>
        <div class="cta-actions">
          <a href="mailto:halo@aruna.id" class="cta-btn-main">
            Kirim Email ↗
          </a>
          <a href="https://wa.me/628xxxxxxx" class="cta-btn-wa">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>

      <div class="cta-details reveal reveal-right">
        <div class="contact-card">
          <div class="contact-item">
            <div class="contact-icon">✉</div>
            <div>
              <div class="contact-label">Email</div>
              <div class="contact-value">halo@aruna.id</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div>
              <div class="contact-label">Kantor</div>
              <div class="contact-value">Jakarta Selatan, Indonesia</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">⏰</div>
            <div>
              <div class="contact-label">Jam Operasional</div>
              <div class="contact-value">Senin–Jumat, 09.00–18.00 WIB</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">⚡</div>
            <div>
              <div class="contact-label">Respons</div>
              <div class="contact-value">Biasanya dalam 2 jam kerja</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer bottom -->
  <div class="footer-bottom">
    <div class="container bottom-inner">
      <a href="/" class="logo">Aruna<span>.</span></a>
      <span class="copy">© 2025 Aruna. Semua hak dilindungi.</span>
      <div class="footer-links">
        <a href="#">Instagram</a>
        <a href="#">LinkedIn</a>
        <a href="#">WhatsApp</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
  }

  .footer-cta {
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .footer-cta::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(200,169,110,0.15) 0%, transparent 70%);
    top: -100px; left: -100px;
    pointer-events: none;
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #fff;
    margin: 16px 0;
  }

  .cta-title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }

  .cta-desc {
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 36px;
    max-width: 400px;
  }

  .cta-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cta-btn-main {
    display: inline-flex;
    align-items: center;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 30px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .cta-btn-main:hover {
    background: var(--color-accent-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(200,169,110,0.4);
  }

  .cta-btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.8);
    padding: 14px 24px;
    border-radius: 100px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: border-color 0.25s, color 0.25s, background 0.25s;
  }

  .cta-btn-wa:hover {
    border-color: rgba(255,255,255,0.5);
    color: #fff;
    background: rgba(255,255,255,0.05);
  }

  /* Contact card */
  .contact-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    backdrop-filter: blur(8px);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .contact-icon {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.08);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .contact-value {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 24px 0;
  }

  .bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
  }

  .logo span { color: var(--color-accent); }

  .copy {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--color-accent); }

  @media (max-width: 768px) {
    .cta-inner { grid-template-columns: 1fr; gap: 40px; }
  }
</style>