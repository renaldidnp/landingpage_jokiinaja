---
const testimonials = [
  {
    name: "Budi Santoso",
    role: "CEO, PT Maju Bersama",
    quote: "Aruna benar-benar mengubah cara kami berbisnis. Strategi mereka jelas, terukur, dan hasilnya luar biasa.",
    avatar: "BS",
    rating: 5,
  },
  {
    name: "Dewi Rahmawati",
    role: "Founder, Studio Kreasi",
    quote: "Tim yang sangat profesional dan responsif. Branding kami jadi jauh lebih kuat setelah bekerja sama dengan Aruna.",
    avatar: "DR",
    rating: 5,
  },
  {
    name: "Arif Wicaksono",
    role: "Direktur, CV Berkah Abadi",
    quote: "Investasi terbaik yang pernah kami lakukan. Website baru kami meningkatkan konversi hingga 3x lipat dalam 2 bulan.",
    avatar: "AW",
    rating: 5,
  },
];
---
<section id="testimoni" class="testimonials">
  <div class="container">
    <div class="testi-header reveal">
      <div class="section-tag">Kata Klien</div>
      <h2 class="section-title">Mereka Sudah Merasakan<br /><em>Perbedaannya</em></h2>
    </div>

    <div class="testi-grid">
      {testimonials.map((t, i) => (
        <div class="testi-card reveal reveal-scale" data-delay={i * 100} data-hover>
          <div class="testi-stars">
            {Array(t.rating).fill('').map(() => <span class="star">★</span>)}
          </div>
          <p class="testi-quote">"{t.quote}"</p>
          <div class="testi-author">
            <div class="avatar">{t.avatar}</div>
            <div>
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust bar -->
    <div class="trust-bar reveal">
      <div class="trust-item">
        <span class="trust-num" data-target="200" data-suffix="+">0+</span>
        <span class="trust-label">Klien Puas</span>
      </div>
      <div class="trust-div"></div>
      <div class="trust-item">
        <span class="trust-num" data-target="98" data-suffix="%">0%</span>
        <span class="trust-label">Tingkat Kepuasan</span>
      </div>
      <div class="trust-div"></div>
      <div class="trust-item">
        <span class="trust-num" data-target="4" data-suffix=".9★">0★</span>
        <span class="trust-label">Rating Google</span>
      </div>
      <div class="trust-div"></div>
      <div class="trust-item">
        <span class="trust-num" data-target="350" data-suffix="+">0+</span>
        <span class="trust-label">Proyek Selesai</span>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 120px 0;
    background: var(--color-bg);
  }

  .testi-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .testi-header .section-tag {
    justify-content: center;
  }

  .testi-header .section-tag::before { display: none; }

  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  .testi-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.35s var(--ease-out-expo),
                box-shadow 0.35s var(--ease-out-expo),
                border-color 0.25s;
  }

  .testi-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.08);
    border-color: var(--color-accent);
  }

  .testi-stars { display: flex; gap: 4px; }

  .star {
    color: var(--color-accent);
    font-size: 1rem;
  }

  .testi-quote {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-primary);
    line-height: 1.65;
    flex: 1;
  }

  .testi-author {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }

  .avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--color-accent-light);
    color: var(--color-accent-dark);
    font-size: 0.78rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 2px solid var(--color-accent);
  }

  .author-name { font-weight: 600; font-size: 0.9rem; }
  .author-role { font-size: 0.78rem; color: var(--color-muted); margin-top: 2px; }

  /* Trust bar */
  .trust-bar {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 20px;
    flex-wrap: wrap;
  }

  .trust-item {
    text-align: center;
  }

  .trust-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .trust-label {
    display: block;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 6px;
  }

  .trust-div {
    width: 1px;
    height: 48px;
    background: var(--color-border);
  }

  @media (max-width: 900px) {
    .testi-grid { grid-template-columns: 1fr; }
    .trust-div { display: none; }
    .trust-bar { gap: 32px; }
  }
</style>