---
const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19.5V5a2 2 0 0 1 2-2h8l6 6v10.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M14 3v6h6"/></svg>`,
    title: "Joki Tugas Kuliah",
    desc: "Membantu pengerjaan makalah, laporan, presentasi, jurnal, hingga tugas akhir dengan hasil rapi dan tepat waktu.",
    num: "01",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 21h8"/></svg>`,
    title: "Pembuatan Website",
    desc: "Landing page, company profile, toko online, hingga dashboard custom dengan desain modern dan performa cepat.",
    num: "02",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-6"/></svg>`,
    title: "Data & Spreadsheet",
    desc: "Pengolahan data Excel, Google Sheets, visualisasi dashboard, serta otomatisasi pekerjaan administrasi.",
    num: "03",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg>`,
    title: "Freelance IT & Coding",
    desc: "Pengerjaan project web, Android, API, scraping, automation, bug fixing, dan kebutuhan teknis lainnya.",
    num: "04",
  },
];
---
<section id="layanan" class="services">
  <div class="container">
    <div class="services-header reveal">
      <div>
        <div class="section-tag">Apa yang Kami Tawarkan</div>
        <h2 class="section-title">Layanan <em>Unggulan</em> Kami</h2>
      </div>
      <p class="services-intro">
        Kami menyediakan berbagai layanan profesional yang dirancang khusus
        untuk kebutuhan unik bisnis Anda.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <div class="service-card reveal reveal-scale" data-delay={i * 100} data-hover>
          <div class="card-top">
            <div class="service-icon" set:html={s.icon} />
            <span class="service-num">{s.num}</span>
          </div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
          <div class="service-footer">
            <a href="#kontak" class="service-link">
              Pelajari lebih →
            </a>
            <div class="service-arrow">↗</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 120px 0;
    background: var(--color-surface);
    position: relative;
  }

  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .services-intro {
    max-width: 360px;
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

 .service-card {
  background: var(--color-surface);
  padding: 36px 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  overflow: hidden;
  min-height: 320px;

  transition:
    transform .35s ease,
    box-shadow .35s ease,
    border-color .35s ease;
}

.service-card:hover {
  transform: translateY(-8px);
  box-shadow:
    0 20px 40px rgba(27,58,107,.10),
    0 8px 16px rgba(27,58,107,.05);
}

.service-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      135deg,
      rgba(232,91,28,.08),
      rgba(232,91,28,.02)
    );
  opacity: 0;
  transition: .35s;
}

.service-card:hover::before {
  opacity: 1;
}
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    background: var(--color-accent-light);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-dark);
    transition: background 0.3s;
  }

  .service-card:hover .service-icon {
    background: var(--color-accent);
    color: white;
  }

  .service-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-border);
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .service-card:hover .service-num { color: var(--color-accent); }

  .service-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--color-brand);
  line-height: 1.3;
}

 .service-desc {
  color: var(--color-muted);
  line-height: 1.8;
  font-size: .95rem;
}

  .service-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .service-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent-dark);
    transition: letter-spacing 0.2s;
  }

  .service-link:hover { letter-spacing: 0.02em; }

  .service-arrow {
    font-size: 1.1rem;
    opacity: 0;
    color: var(--color-accent);
    transform: translate(-4px, 4px);
    transition: opacity 0.3s, transform 0.3s;
  }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
    .services-header { flex-direction: column; }
  }

  @media (max-width: 560px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>