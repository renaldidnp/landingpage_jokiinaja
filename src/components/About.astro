      </a>
    </div>

  </div>
</section>

<style>
  /* ────────────────────────────────────
     ABOUT SECTION
  ──────────────────────────────────── */
  .about {
    padding: 100px 0;
    background: var(--color-bg);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  /* ── Visual Column ── */
  .about-visual {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .a-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px 22px;
    transition: box-shadow 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
  }
  .a-card:hover {
    box-shadow: 0 8px 32px rgba(27,58,107,0.10);
    transform: translateY(-3px);
  }

  .a-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* Tech card */
  .tech-header { margin-bottom: 14px; }
  .tech-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    display: inline-block;
    background: var(--color-surface-alt);
    color: var(--color-navy);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid var(--color-border);
  }
  .chip-more {
    background: var(--color-orange-light);
    color: var(--color-orange-dark);
    border-color: rgba(232,91,28,0.2);
  }

  /* Rating row */
  .rating-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .rating-card, .exp-card { text-align: center; }
  .rating-top {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  .rating-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1;
  }
  .rating-stars { color: #f59e0b; font-size: 0.75rem; letter-spacing: 2px; }

  .exp-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1;
    margin-bottom: 4px;
  }

  /* Flow card */
  .flow-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
  }
  .flow-icon {
    width: 40px; height: 40px;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
  }
  .flow-step span {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-navy);
    text-align: center;
  }
  .flow-arrow {
    color: var(--color-orange);
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Content Column ── */
  .about-content .section-title em {
    font-style: italic;
    font-weight: 700;
    color: var(--color-orange);
  }

  .about-desc {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 28px;
    max-width: 480px;
  }

  /* List */
  .about-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 36px;
  }
  .about-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .list-icon {
    color: var(--color-orange);
    font-size: 0.9rem;
    margin-top: 3px;
    flex-shrink: 0;
    font-weight: 700;
  }
  .about-list strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 2px;
  }
  .about-list p {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* CTA */
  .about-content .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 968px) {
    .about-inner { grid-template-columns: 1fr; gap: 48px; }
    .about-visual { order: 2; }
    .about-content { order: 1; }
  }

  @media (max-width: 480px) {
    .about { padding: 72px 0; }
    .rating-row { grid-template-columns: 1fr 1fr; }
    .flow-step span { font-size: 0.68rem; }
  }
</style>