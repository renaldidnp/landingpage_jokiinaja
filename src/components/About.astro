<section id="tentang" class="about" aria-labelledby="about-heading">
  <div class="container about-inner">

    <!-- ── LEFT: Interactive Cards ── -->
    <div class="about-visual" aria-hidden="true">

      <!-- Card: Stack teknologi -->
      <div class="a-card tech-card reveal reveal-scale" data-delay="100">
        <div class="tech-header">
          <span class="a-label">Tech Stack Kami</span>
        </div>
        <div class="tech-chips">
          <span class="chip">React</span>
          <span class="chip">Laravel</span>
          <span class="chip">Node.js</span>
          <span class="chip">Python</span>
          <span class="chip">MySQL</span>
          <span class="chip">Flutter</span>
          <span class="chip">TensorFlow</span>
<span class="chip">Arduino</span>
<span class="chip">Figma</span>
          <span class="chip chip-more">+12 lainnya</span>
        </div>
      </div>

      <!-- Card: Rating -->
      <div class="rating-row">
        <div class="a-card rating-card reveal reveal-scale" data-delay="220">
          <div class="rating-top">
            <span class="rating-num">4.9</span>
            <div class="rating-stars">★★★★★</div>
          </div>
          <span class="a-label">Rating Klien</span>
        </div>
        <div class="a-card exp-card reveal reveal-scale" data-delay="320">
          <span class="exp-num" data-target="3" data-suffix="+">0+</span>
          <span class="a-label">Tahun Pengalaman</span>
        </div>
      </div>

      <!-- Card: Proses -->
      <div class="a-card flow-card reveal reveal-scale" data-delay="420">
        <span class="a-label" style="margin-bottom:12px;display:block;">Alur Pengerjaan</span>
        <div class="flow-steps">
         <div class="flow-step">
  <div class="flow-icon">💬</div>
  <span>Konsultasi</span>
</div>
<div class="flow-arrow">→</div>
<div class="flow-step">
  <div class="flow-icon">📋</div>
  <span>Brief & Harga</span>
</div>
<div class="flow-arrow">→</div>
<div class="flow-step">
  <div class="flow-icon">⚙️</div>
  <span>Pengerjaan</span>
</div>
<div class="flow-arrow">→</div>
<div class="flow-step">
  <div class="flow-icon">✅</div>
  <span>Revisi & Kirim</span>
</div>
        </div>
      </div>

    </div>

    <!-- ── RIGHT: Copy ── -->
    <div class="about-content">
      <div class="section-tag">Tentang JokiinAja</div>

      <h2 class="section-title" id="about-heading">
  Bukan Sekadar Joki —<br />
  <em>Partner IT</em> Kamu.
</h2>

      <p class="about-desc">
        JokiinAja adalah tim developer dan akademisi berpengalaman yang siap membantu 
kamu — dari tugas kuliah, skripsi IT, hingga proyek digital nyata seperti 
website, Machine Learning, IoT, dan UI/UX — dikerjakan profesional, tepat waktu, dan aman.
      </p>

      <ul class="about-list" role="list">
        <li>
          <span class="list-icon" aria-hidden="true">✦</span>
          <div>
            <strong>Developer Berpengalaman</strong>
            <p>Tim kami adalah praktisi aktif di industri IT, bukan sekadar mahasiswa.</p>
          </div>
        </li>
        <li>
          <span class="list-icon" aria-hidden="true">✦</span>
          <div>
            <strong>Dikerjakan Sesuai Dosen</strong>
            <p>Kami pelajari brief-mu dulu — hasil disesuaikan gaya kampus dan mata kuliah.</p>
          </div>
        </li>
        <li>
          <span class="list-icon" aria-hidden="true">✦</span>
          <div>
            <strong>Garansi Revisi Tanpa Batas</strong>
            <p>Selama masih dalam scope yang disepakati, revisi gratis hingga puas.</p>
          </div>
        </li>
        <li>
          <span class="list-icon" aria-hidden="true">✦</span>
          <div>
            <strong>Konsultasi 24 Jam</strong>
            <p>Deadline mendadak? Kami siap dihubungi kapan saja via WhatsApp.</p>
          </div>
        </li>
      </ul>

      <a
        href="https://wa.me/6281234567890?text=Halo,%20saya%20mau%20tahu%20lebih%20lanjut%20tentang%20JokiinAja"
        class="btn-primary"
        rel="noopener"
        aria-label="Hubungi JokiinAja untuk informasi lebih lanjut"
      >
        Kenali Kami Lebih Dekat
