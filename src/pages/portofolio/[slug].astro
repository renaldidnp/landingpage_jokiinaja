---
// src/pages/portofolio/[slug].astro
// ⚠️  Ganti nama Layout sesuai milik Anda
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

// Nomor WhatsApp Anda — ganti di sini saja
const WA_NUMBER = '6281234567890';

export function getStaticPaths() {
  return projects.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project   = projects.find(p => p.slug === slug);
if (!project) return Astro.redirect('/404');

// ── SEO ──────────────────────────────────────────────────────────────
const siteUrl    = 'https://jokiinaja.my.id'; // ← ganti domain Anda
const pageUrl    = `${siteUrl}/portofolio/${project.slug}`;
const metaTitle = `${project.title} | Portofolio Joki IT & Skripsi`;

const metaDesc =
  `${project.desc} Hasil: ${project.result}. Portofolio pengerjaan aplikasi, machine learning, data mining, scraping, NLP, SPK, dan proyek skripsi IT.`;

// WhatsApp pesan otomatis sesuai proyek
const waMessage  = encodeURIComponent(
  `Halo, saya tertarik dengan layanan seperti proyek "${project.title}". Boleh konsultasi?`
);
const waUrl      = `https://wa.me/${WA_NUMBER}?text=${waMessage}`;

// JSON-LD structured data
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": project.title,
  "description": metaDesc,
  "url": pageUrl,
  "datePublished": `${project.year}-01-01`,
  "publisher": {
    "@type": "Organization",
    "name": "Joki Ina Ja",
    "url": siteUrl
  },
  "mainEntityOfPage": pageUrl,
});
---

<Layout title={metaTitle} description={metaDesc}>
  <!-- SEO extras di <head> via slot -->
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title"       content={metaTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:url"         content={pageUrl} />
    <meta property="og:type"        content="article" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={metaTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <main class="detail-page">
      <div class="hero-badge">{project.year}</div>
    </div>

    <div class="detail-wrap">

      <!-- ── Breadcrumb (SEO) ── -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Beranda</a>
        <span>/</span>
        <a href="/#portofolio">Portofolio</a>
        <span>/</span>
        <span aria-current="page">{project.title}</span>
      </nav>

      <!-- ── Dua kolom: konten + sidebar ── -->
      <div class="detail-layout">

        <!-- Konten utama -->
        <article class="detail-main">

          <!-- Header artikel -->
          <header class="detail-header">
            <span class="detail-category">{project.category}</span>
            <h1 class="detail-title">{project.title}</h1>
            <p class="detail-lead">{project.desc}</p>

            <div class="detail-meta-row">
              <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>{project.client}</span>
              </div>
              <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{project.duration}</span>
              </div>
              <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Tim {project.team}</span>
              </div>
            </div>

            <div class="detail-tags">
              {project.tags.map(tag => <span class="dtag">{tag}</span>)}
            </div>
          </header>

{
  project.image && (
    <div class="project-image-wrap">
      <img
        src={project.image}
        alt={project.title}
        class="project-image"
      />
    </div>
  )
}
          <!-- Result highlight -->
          <div class="result-highlight">
            <div class="rh-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
            </div>
            <div>
              <div class="rh-label">Hasil yang Dicapai</div>
              <div class="rh-value">{project.result}</div>
            </div>
          </div>

          <!-- Sections -->
          <div class="content-sections">

            <section class="cs-block">
              <h2>
                <span class="cs-num">01</span>
                Tentang Proyek
              </h2>
              <p>{project.fullDesc}</p>
            </section>

            <section class="cs-block">
              <h2>
                <span class="cs-num">02</span>
                Tantangan
              </h2>
              <p>{project.challenge}</p>
            </section>

            <section class="cs-block">
              <h2>
                <span class="cs-num">03</span>
                Solusi yang Kami Berikan
              </h2>
              <p>{project.solution}</p>
            </section>

            <section class="cs-block">
              <h2>
                <span class="cs-num">04</span>
                Hasil &amp; Dampak
              </h2>
              <ul class="outcomes">
                {project.outcomes.map(o => (
                  <li>
                    <span class="oc-check">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    {o}
                  </li>
                ))}
              </ul>
            </section>

          </div>
        </article>

        <!-- ── Sidebar sticky ── -->
        <aside class="detail-sidebar">

          <!-- CTA utama -->
          <div class="sidebar-cta">
            <div class="cta-header">
              <div class="cta-avatar">🚀</div>
              <div>
                <div class="cta-title">Tertarik proyek serupa?</div>
                <div class="cta-sub">Konsultasi gratis via WhatsApp</div>
              </div>
            </div>
            <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-wa">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat WhatsApp Sekarang
            </a>
            <p class="cta-note">Biasanya dibalas dalam 5 menit ⚡</p>
          </div>

          <!-- Info proyek -->
          <div class="sidebar-info">
            <div class="si-title">Info Proyek</div>
            <div class="si-row"><span>Klien</span><strong>{project.client}</strong></div>
            <div class="si-row"><span>Kategori</span><strong>{project.category}</strong></div>
            <div class="si-row"><span>Durasi</span><strong>{project.duration}</strong></div>
            <div class="si-row"><span>Tim</span><strong>{project.team}</strong></div>
            <div class="si-row"><span>Tahun</span><strong>{project.year}</strong></div>
            <div class="si-row result-row">
              <span>Hasil</span>
              <strong class="result-pill">{project.result}</strong>
            </div>
          </div>

          <!-- Trust signals -->
          <div class="sidebar-trust">
            <div class="trust-item">
              <span class="trust-icon">✓</span>
              <span>Pengerjaan tepat waktu</span>
            </div>
            <div class="trust-item">
              <span class="trust-icon">✓</span>
              <span>Revisi hingga puas</span>
            </div>
            <div class="trust-item">
              <span class="trust-icon">✓</span>
              <span>Harga transparan</span>
            </div>
            <div class="trust-item">
              <span class="trust-icon">✓</span>
              <span>Source code disertakan</span>
            </div>
          </div>

        </aside>

      </div>

      <!-- ── CTA bawah (mobile-friendly) ── -->
      <div class="bottom-cta">
        <div class="bc-text">
          <h2>Punya proyek serupa?</h2>
          <p>Ceritakan kebutuhan Anda — kami siap bantu dari nol sampai selesai.</p>
        </div>
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-wa large">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Konsultasi Gratis via WhatsApp
        </a>
      </div>

    </div><!-- /detail-wrap -->

    <!-- Floating WA button -->
    <a href={waUrl} target="_blank" rel="noopener noreferrer" class="wa-float" aria-label="Chat WhatsApp">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

  </main>
</Layout>

<style>

.project-image-wrap {
  margin: 24px 0 32px;
}

.project-image {
  width: 100%;
  border-radius: 16px;
  display: block;
  object-fit: cover;
  border: 1px solid var(--color-border);
}
/* ── Base ── */
.detail-page { min-height: 100vh; background: var(--color-bg); }

/* ── Hero ── */
.detail-hero {
  width: 100%;
  height: 280px;
  background: var(--card-color, #f0f0f0);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.hero-mockup {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(10px);
  border-radius: 12px;
  padding: 20px 28px;
  width: min(380px, 55%);
  box-shadow: 0 12px 40px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  gap: 9px;
}

.hm-topbar {
  display: flex;
  gap: 5px;
  margin-bottom: 4px;
}

.hm-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(0,0,0,0.15);
}

.hm-bar        { height: 8px; background: rgba(0,0,0,0.1); border-radius: 4px; width: 100%; }
.hm-bar.short  { width: 40%; }
.hm-bar.medium { width: 65%; }

.hero-badge {
  position: absolute;
  bottom: 18px;
  right: 20px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(6px);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--color-muted);
  padding: 5px 14px;
  border-radius: 100px;
}

/* ── Wrapper ── */
.detail-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 24px 80px;
}

/* ── Breadcrumb ── */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.78rem;
  color: var(--color-muted);
  margin-bottom: 36px;
  flex-wrap: wrap;
}

.breadcrumb a {
  color: var(--color-muted);
  text-decoration: none;
  transition: color 0.2s;
}

.breadcrumb a:hover { color: var(--color-accent); }
.breadcrumb span[aria-current] { color: var(--color-primary); font-weight: 500; }

/* ── Layout dua kolom ── */
.detail-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 40px;
  align-items: start;
}

/* ── Artikel utama ── */
.detail-main { min-width: 0; }

.detail-header { margin-bottom: 28px; }

.detail-category {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  background: var(--color-accent-light);
  padding: 4px 14px;
  border-radius: 100px;
  margin-bottom: 14px;
}

.detail-title {
  font-family: var(--font-display);
  font-size: clamp(1.7rem, 3.5vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.15;
  color: var(--color-primary);
  margin-bottom: 14px;
}

.detail-lead {
  font-size: 1rem;
  color: var(--color-muted);
  line-height: 1.75;
  margin-bottom: 20px;
  max-width: 580px;
}

.detail-meta-row {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: var(--color-muted);
}

.detail-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.dtag {
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--color-muted);
  border: 1px solid var(--color-border);
  border-radius: 100px;
  padding: 3px 12px;
}

/* ── Result highlight ── */
.result-highlight {
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--color-green-light, #e6f7ee);
  border-left: 4px solid var(--color-green, #22c55e);
  border-radius: 0 10px 10px 0;
  padding: 18px 24px;
  margin-bottom: 36px;
}

.rh-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--color-green, #22c55e);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rh-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-green, #22c55e);
  margin-bottom: 3px;
}

.rh-value {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-primary);
}

/* ── Content sections ── */
.content-sections { display: flex; flex-direction: column; gap: 0; }

.cs-block {
  padding: 28px 0;
  border-top: 1px solid var(--color-border);
}

.cs-block:last-child { border-bottom: 1px solid var(--color-border); }

.cs-block h2 {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 14px;
  letter-spacing: -0.02em;
}

.cs-num {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--color-muted);
  opacity: 0.5;
}

.cs-block p {
  font-size: 0.93rem;
  color: var(--color-muted);
  line-height: 1.85;
}

/* ── Outcomes ── */
.outcomes { list-style: none; display: flex; flex-direction: column; gap: 10px; }

.outcomes li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.92rem;
  color: var(--color-muted);
  line-height: 1.65;
}

.oc-check {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--color-green, #22c55e);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}

/* ── Sidebar ── */
.detail-sidebar {
  position: sticky;
  top: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* CTA card */
.sidebar-cta {
  background: var(--color-primary);
  border-radius: 16px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.cta-header {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cta-avatar {
  width: 44px;
  height: 44px;
  background: rgba(255,255,255,0.15);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  flex-shrink: 0;
}

.cta-title {
  font-weight: 700;
  font-size: 0.95rem;
  color: #fff;
  margin-bottom: 2px;
}

.cta-sub {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.6);
}

.cta-note {
  text-align: center;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  margin: 0;
}

/* WA button */
.btn-wa {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: #25D366;
  color: #fff;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 14px 20px;
  border-radius: 10px;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 4px 16px rgba(37,211,102,0.35);
}

.btn-wa:hover {
  background: #1ebe5d;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37,211,102,0.45);
}

.btn-wa.large {
  font-size: 1rem;
  padding: 16px 28px;
  border-radius: 12px;
}

/* Sidebar info */
.sidebar-info {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 14px;
  padding: 20px;
